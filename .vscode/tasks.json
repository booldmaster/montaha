{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Quartz: Build & Serve",
            "type": "shell",
            "command": "npx quartz build --serve",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Quartz: Sync",
            "type": "shell",
            "command": "npx quartz sync",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}