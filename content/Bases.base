views:
  - type: table
    name: Table
    filters:
      and:
        - file.hasProperty("type")
    order:
      - file.name
      - aliases
      - tags
      - type
    sort:
      - property: entity
        direction: ASC
      - property: location
        direction: ASC
      - property: file.name
        direction: ASC
  - type: list
    name: Albedo
    order:
      - file.name
